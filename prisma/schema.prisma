generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// Auth.js required models (Prisma adapter v2)
// ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// Core models
// ──────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  // Auth.js required fields
  name              String?
  email             String?   @unique
  emailVerified     DateTime?
  image             String?
  accounts          Account[]
  sessions          Session[]

  // Century Financial fields
  legacyId          String    @unique  // maps to old id like 'arun.john'
  displayName       String
  title             String
  role              Role
  tier              Tier
  passwordHash      String
  passwordChangedAt DateTime?           // null = never changed (force change on next login)
  passwordExpiresAt DateTime?
  failedAttempts    Int       @default(0)
  lockedUntil       DateTime?
  mfaEnabled        Boolean   @default(false)
  mfaSecret         String?             // AES-256-GCM encrypted TOTP secret
  mfaEnrolledAt     DateTime?
  pendingMfaSecret  String?             // Temp secret during enrollment flow

  // Performance metrics
  hitRate           Float     @default(0)
  avgRet            Float     @default(0)
  sharpe            Float     @default(0)
  drawCtrl          Float     @default(0)
  consistency       Float     @default(0)
  peerScore         Float     @default(0)
  ideaScore         Float     @default(0)
  allocScore        Float     @default(0)
  researchScore     Float     @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  passwordHistory   PasswordHistory[]
  resetTokens       PasswordResetToken[]
  mfaTokens         MfaToken[]
  auditLogs         AuditLog[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  // Extra tracking fields
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Short-lived token for MFA step-2 after password validation
model MfaToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  detail    String      @db.Text
  ipAddress String?
  device    String?
  risk      RiskLevel   @default(LOW)
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum Role {
  CIO
  PM
  SR_ANALYST
  ANALYST
}

enum Tier {
  A_PLUS
  A
  B
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGIN_MFA_SUCCESS
  LOGIN_MFA_FAILED
  LOGOUT
  SESSION_TERMINATED
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  MFA_ENROLLED
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  IDEA_SUBMITTED
  TRADE_APPROVED
  BALLOT_SUBMITTED
  PERMISSION_CHANGE
  VOTE_CAST
  ALLOCATION_ADJUSTED
  LOGIN_ANOMALY
  SESSION_STARTED
  RESEARCH_CREATED
  RESEARCH_UPDATED
  COMMENT_POSTED
  ATTACHMENT_ADDED
  WATCHLIST_CREATED
  CALENDAR_EVENT_ADDED
  POST_MORTEM_CREATED
  TRADE_PROPOSAL_CREATED
  TRADE_PROPOSAL_APPROVED
  POSITION_OPENED
  POSITION_CLOSED
  POSITION_UPDATED
  PARTIAL_EXIT_RECORDED
  TRADE_ALERT_CREATED
  TRADE_JOURNAL_UPDATED
  TRADE_CANCELLED
  COMMITTEE_QUESTION_RAISED
  COMMITTEE_CHALLENGE_RAISED
  COMMITTEE_CHALLENGE_RESOLVED
  VOTE_JUSTIFICATION_SUBMITTED
  MEETING_CREATED
  MEETING_COMPLETED
  ALLOCATION_QUEUE_UPDATED
  RESEARCH_REVISION_SUBMITTED
  DECISION_PACKAGE_GENERATED
  MT5_SNAPSHOT_CREATED
  MT5_SERVICE_UNAVAILABLE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String
  type      String
  createdAt DateTime @default(now())

  @@index([key, type, createdAt])
}

// ──────────────────────────────────────────────
// Phase 3 — Research OS models
// ──────────────────────────────────────────────

model ResearchDoc {
  id              String         @id @default(cuid())
  ideaId          String         @unique
  idea            Idea           @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  status          ResearchStatus @default(DRAFT)
  templateType    String?
  // Rich text sections (plain text / markdown stored)
  thesis          String?        @db.Text
  financials      String?        @db.Text
  valuation       String?        @db.Text
  technical       String?        @db.Text
  overview        String?        @db.Text
  // Computed scores (updated on save)
  completionScore Int            @default(0)
  qualityScore    Int            @default(0)
  authorId        String
  lastEditedBy    String?
  lastEditedAt    DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  versions        ResearchVersion[]
  catalysts       ResearchCatalyst[]
  risks           ResearchRisk[]
  attachments     ResearchAttachment[]
  references      ResearchReference[]
  comments        ResearchComment[]
  revisionRecords ResearchRevisionRecord[]

  @@index([authorId])
  @@index([status])
}

model ResearchVersion {
  id        String      @id @default(cuid())
  docId     String
  doc       ResearchDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  field     String
  content   String      @db.Text
  authorId  String
  createdAt DateTime    @default(now())

  @@index([docId, field])
}

model ResearchCatalyst {
  id             String      @id @default(cuid())
  docId          String
  doc            ResearchDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  title          String
  description    String      @db.Text
  expectedImpact String?
  probability    Int?
  timeline       String?
  importance     String      @default("MEDIUM")
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([docId])
}

model ResearchRisk {
  id             String      @id @default(cuid())
  docId          String
  doc            ResearchDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  description    String      @db.Text
  severity       String      @default("MEDIUM")
  probability    Int?
  mitigation     String?     @db.Text
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([docId])
}

model ResearchAttachment {
  id          String      @id @default(cuid())
  docId       String
  doc         ResearchDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  title       String
  description String?
  fileType    String
  fileUrl     String      @db.Text
  fileSize    Int?
  uploadedBy  String
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?

  @@index([docId])
}

model ResearchReference {
  id          String      @id @default(cuid())
  docId       String
  doc         ResearchDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  title       String
  source      String
  url         String?     @db.Text
  publishDate DateTime?
  notes       String?     @db.Text
  addedBy     String
  createdAt   DateTime    @default(now())

  @@index([docId])
}

model ResearchComment {
  id        String          @id @default(cuid())
  docId     String
  doc       ResearchDoc     @relation(fields: [docId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    ResearchComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   ResearchComment[] @relation("CommentReplies")
  authorId  String
  content   String          @db.Text
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?

  @@index([docId])
  @@index([parentId])
}

model Watchlist {
  id          String          @id @default(cuid())
  name        String
  description String?
  ownerId     String
  isPublic    Boolean         @default(false)
  color       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  items WatchlistItem[]

  @@index([ownerId])
}

model WatchlistItem {
  id          String    @id @default(cuid())
  watchlistId String
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  ticker      String
  notes       String?
  addedBy     String
  addedAt     DateTime  @default(now())

  @@unique([watchlistId, ticker])
  @@index([watchlistId])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  eventType   String
  date        DateTime
  ticker      String?
  ideaId      String?
  description String?  @db.Text
  importance  String   @default("MEDIUM")
  createdBy   String
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([ticker])
}

model PostMortem {
  id             String    @id @default(cuid())
  ideaId         String    @unique
  idea           Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  authorId       String
  entryDate      DateTime?
  exitDate       DateTime?
  entryPrice     Float?
  exitPrice      Float?
  actualReturn   Float?
  maxDrawdown    Float?
  holdDays       Int?
  originalThesis String?   @db.Text
  whatWorked     String?   @db.Text
  whatFailed     String?   @db.Text
  mistakes       String?   @db.Text
  lessonsLearned String?   @db.Text
  futureAction   String?   @db.Text
  committeeNotes String?   @db.Text
  rating         Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([authorId])
}

enum ResearchStatus {
  DRAFT
  IN_PROGRESS
  COMPLETE
  RISK_REVIEW
  COMMITTEE_REVIEW
  ARCHIVED
}

// ──────────────────────────────────────────────
// Business models
// ──────────────────────────────────────────────

model Idea {
  id              String         @id
  ticker          String
  assetClass      String         @default("US Equities")
  dir             Direction
  entry           Float
  stop            Float
  target          Float
  hold            String         @default("1-3M")
  posSize         Float          @default(1)
  conv            Int            @default(7)
  expRet          Float          @default(0)
  expDD           Float          @default(0)
  rr              Float          @default(0)
  thesis          String         @db.Text
  catalysts       String[]
  risks           String[]
  authorId        String
  submittedAt     DateTime       @default(now())
  weekId          String
  status          String         @default("ACTIVE")
  approvalStatus  ApprovalStatus @default(PENDING)
  imageUrl        String?        @db.Text
  totalCredits    Int            @default(0)
  rank            Int            @default(0)
  pmScore         Float          @default(0)
  skillScore      Float          @default(0)
  rrScore         Float          @default(0)
  quantScore      Float          @default(0)
  finalScore      Float          @default(0)
  momentumScore   Float          @default(0)
  rsScore         Float          @default(0)
  earningRevScore Float          @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  allocations        Allocation[]
  researchDoc        ResearchDoc?
  postMortem         PostMortem?
  trades             Trade[]
  meetingItems       MeetingAgendaItem[]
  questions          CommitteeQuestion[]
  challenges         CommitteeChallenge[]
  voteJustifications VoteJustification[]
  allocationQueue    AllocationQueueEntry?
  decisionPackages   DecisionPackage[]
  marketSnapshot     IdeaMarketSnapshot?
  quantScoreData     IdeaQuantScore?

  @@index([weekId])
  @@index([authorId])
}

model Allocation {
  id          String   @id @default(cuid())
  userId      String
  ideaId      String
  amount      Int
  round       Int      @default(1)
  weekId      String
  submittedAt DateTime @default(now())
  idea        Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([userId, ideaId, round, weekId])
  @@index([weekId])
  @@index([userId, weekId])
}

enum Direction {
  LONG
  SHORT
}

enum ApprovalStatus {
  APPROVED
  PENDING
  REVIEW
  REJECTED
}

// ──────────────────────────────────────────────
// Phase 4 — Portfolio & Trade Management
// ──────────────────────────────────────────────

enum TradeStatus {
  PROPOSAL
  APPROVED
  ACTIVE
  PARTIAL_EXIT
  CLOSED
  CANCELLED
}

enum ExecutionType {
  ENTRY
  ADD
  PARTIAL_EXIT
  FULL_EXIT
  STOP_LOSS
  STOP_ADJUSTED
  TARGET_ADJUSTED
  NOTE
}

enum AlertType {
  STOP_LOSS_HIT
  TARGET_HIT
  EARNINGS_DATE
  HIGH_DRAWDOWN
  POSITION_AGE
  CONCENTRATION
  MARGIN_THRESHOLD
  MANUAL_REVIEW
}

model Trade {
  id              String      @id @default(cuid())
  ideaId          String
  idea            Idea        @relation(fields: [ideaId], references: [id])
  status          TradeStatus @default(PROPOSAL)
  side            String      @default("BUY")
  exchange        String?
  currency        String      @default("USD")
  strategy        String?
  timeHorizon     String?
  convictionLevel Int?
  holdingPeriod   String?
  entryPrice      Float?
  stopLoss        Float?
  target1         Float?
  target2         Float?
  target3         Float?
  riskReward      Float?
  positionSize    Float?
  maxCapital      Float?
  maxExposurePct  Float?
  tradeRationale  String?     @db.Text
  cioNotes        String?     @db.Text
  pmNotes         String?     @db.Text
  executionNotes  String?     @db.Text
  proposedBy      String
  approvedBy      String?
  proposedAt      DateTime    @default(now())
  approvedAt      DateTime?
  closedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  executions  TradeExecution[]
  position    Position?
  journal     TradeJournal[]
  alerts      TradeAlert[]
  history     PositionHistory[]
  attribution PerformanceAttribution?

  @@index([ideaId])
  @@index([proposedBy])
  @@index([status])
}

model TradeExecution {
  id          String        @id @default(cuid())
  tradeId     String
  trade       Trade         @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  type        ExecutionType
  price       Float
  quantity    Float
  value       Float
  fees        Float         @default(0)
  executedBy  String
  executedAt  DateTime      @default(now())
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())

  @@index([tradeId])
}

model Position {
  id              String    @id @default(cuid())
  tradeId         String    @unique
  trade           Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  ticker          String
  direction       String
  quantity        Float
  avgCost         Float
  currentPrice    Float?
  marketValue     Float?
  unrealizedPnl   Float?
  realizedPnl     Float     @default(0)
  returnPct       Float?
  maxGain         Float?
  maxDrawdown     Float?
  daysHeld        Int       @default(0)
  stopLoss        Float?
  target          Float?
  entryDate       DateTime
  exitDate        DateTime?
  lastPriceUpdate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([ticker])
}

model PositionHistory {
  id          String    @id @default(cuid())
  tradeId     String
  trade       Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  eventType   String
  description String    @db.Text
  price       Float?
  quantity    Float?
  value       Float?
  createdBy   String
  createdAt   DateTime  @default(now())

  @@index([tradeId])
  @@index([createdAt])
}

model TradeJournal {
  id          String    @id @default(cuid())
  tradeId     String
  trade       Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  field       String
  content     String    @db.Text
  authorId    String
  authorRole  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tradeId, field])
  @@index([tradeId])
}

model PortfolioSnapshot {
  id            String    @id @default(cuid())
  snapshotDate  DateTime
  totalEquity   Float     @default(0)
  cashBalance   Float     @default(0)
  totalExposure Float     @default(0)
  netExposure   Float     @default(0)
  grossExposure Float     @default(0)
  unrealizedPnl Float     @default(0)
  realizedPnl   Float     @default(0)
  openPositions Int       @default(0)
  createdAt     DateTime  @default(now())

  @@index([snapshotDate])
}

model TradeAlert {
  id        String    @id @default(cuid())
  tradeId   String?
  trade     Trade?    @relation(fields: [tradeId], references: [id], onDelete: SetNull)
  alertType AlertType
  message   String    @db.Text
  severity  String    @default("MEDIUM")
  isRead    Boolean   @default(false)
  readAt    DateTime?
  readBy    String?
  createdAt DateTime  @default(now())

  @@index([isRead])
  @@index([tradeId])
}

model PerformanceAttribution {
  id               String    @id @default(cuid())
  tradeId          String    @unique
  trade            Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  researchQuality  Int?
  entryTiming      Int?
  exitTiming       Int?
  catalystOutcome  Int?
  riskMgmt         Int?
  positionSizing   Int?
  executionQuality Int?
  analystComment   String?   @db.Text
  pmComment        String?   @db.Text
  cioComment       String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ──────────────────────────────────────────────
// Phase 5 — Investment Decision Engine
// ──────────────────────────────────────────────

model CommitteeMeeting {
  id          String   @id @default(cuid())
  title       String
  meetingDate DateTime
  agenda      String?  @db.Text
  notes       String?  @db.Text
  decisions   String?  @db.Text
  status      String   @default("SCHEDULED")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agendaItems MeetingAgendaItem[]
  attendance  MeetingAttendance[]

  @@index([meetingDate])
  @@index([status])
}

model MeetingAgendaItem {
  id        String           @id @default(cuid())
  meetingId String
  meeting   CommitteeMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  ideaId    String
  idea      Idea             @relation(fields: [ideaId], references: [id])
  sortOrder Int              @default(0)
  notes     String?
  duration  Int?
  createdAt DateTime         @default(now())

  @@unique([meetingId, ideaId])
  @@index([meetingId])
  @@index([ideaId])
}

model MeetingAttendance {
  id        String           @id @default(cuid())
  meetingId String
  meeting   CommitteeMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  attended  Boolean          @default(true)
  role      String?
  createdAt DateTime         @default(now())

  @@unique([meetingId, userId])
  @@index([meetingId])
}

model CommitteeQuestion {
  id         String    @id @default(cuid())
  ideaId     String
  idea       Idea      @relation(fields: [ideaId], references: [id])
  raisedBy   String
  assignedTo String?
  question   String    @db.Text
  answer     String?   @db.Text
  status     String    @default("OPEN")
  priority   String    @default("MEDIUM")
  answeredBy String?
  answeredAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([ideaId])
  @@index([status])
}

model CommitteeChallenge {
  id          String    @id @default(cuid())
  ideaId      String
  idea        Idea      @relation(fields: [ideaId], references: [id])
  raisedBy    String
  category    String
  description String    @db.Text
  evidence    String?   @db.Text
  priority    String    @default("MEDIUM")
  status      String    @default("OPEN")
  resolution  String?   @db.Text
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ideaId])
  @@index([status])
}

model VoteJustification {
  id              String   @id @default(cuid())
  ideaId          String
  idea            Idea     @relation(fields: [ideaId], references: [id])
  userId          String
  decision        String
  summary         String   @db.Text
  keyStrengths    String?  @db.Text
  keyConcerns     String?  @db.Text
  conditions      String?  @db.Text
  additionalNotes String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([ideaId, userId])
  @@index([ideaId])
}

model ResearchRevisionRecord {
  id          String      @id @default(cuid())
  docId       String
  doc         ResearchDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  revisionNum Int
  summary     String      @db.Text
  changes     String?     @db.Text
  submittedBy String
  createdAt   DateTime    @default(now())

  @@index([docId])
}

model AllocationQueueEntry {
  id                  String   @id @default(cuid())
  ideaId              String   @unique
  idea                Idea     @relation(fields: [ideaId], references: [id])
  rank                Int?
  capitalRequested    Float?
  recommendedAlloc    Float?
  portfolioExposurePct Float?
  riskRating          String   @default("MEDIUM")
  status              String   @default("PENDING")
  notes               String?  @db.Text
  updatedBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
}

model DecisionPackage {
  id          String   @id @default(cuid())
  ideaId      String
  idea        Idea     @relation(fields: [ideaId], references: [id])
  version     Int      @default(1)
  generatedBy String
  content     String   @db.Text
  createdAt   DateTime @default(now())

  @@index([ideaId])
}

// ──────────────────────────────────────────────
// MT5 Market Snapshot — immutable audit record
// Fields: cmp, bid, ask, spread, mt5ServerTime,
//         submittedAtUtc, submissionIp are NEVER
//         editable after creation.
// ──────────────────────────────────────────────

model IdeaMarketSnapshot {
  id                 String   @id @default(cuid())
  ideaId             String   @unique
  idea               Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  // Analyst context (set at creation, immutable)
  analystId          String
  analystRole        String

  // MT5 market data at exact moment of submission (immutable)
  symbol             String
  cmp                Float             // mid price — becomes the idea entry price
  bid                Float
  ask                Float
  spread             Float
  mt5ServerTime      DateTime
  marketStatus       String            // OPEN | CLOSED | SHORT_ONLY | LONG_ONLY
  exchange           String            @default("MT5")
  timeZone           String            @default("UTC")

  // Idea parameters snapshot (immutable)
  direction          String
  targetPrice        Float
  stopPrice          Float
  timeHorizon        String
  weekId             String
  weekNumber         Int
  votingCycle        String

  // Submission audit metadata (immutable)
  submittedAtUtc     DateTime          @default(now())
  tradingDay         String
  marketSession      String            @default("UNKNOWN")
  submissionIp       String?
  submissionDevice   String?
  submissionBrowser  String?

  // Live performance tracking (updated by background refresh — NOT part of immutable record)
  currentPrice       Float?
  currentPnlPct      Float?
  currentPnlAbs      Float?
  distanceToTarget   Float?
  distanceToStop     Float?
  mfe                Float?            // Maximum Favorable Excursion
  mae                Float?            // Maximum Adverse Excursion
  tradeStatus        String            @default("OPEN") // OPEN | TARGET_HIT | STOP_HIT | EXPIRED | CLOSED
  lastPriceUpdate    DateTime?

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([analystId])
  @@index([weekId])
  @@index([tradeStatus])
}

// ──────────────────────────────────────────────
// MT5 Quantitative Score — computed at submission
// from historical + live MT5 data.
// quantScore on Idea is updated to match finalQuantScore.
// ──────────────────────────────────────────────

model IdeaQuantScore {
  id        String   @id @default(cuid())
  ideaId    String   @unique
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  direction String

  // Raw MT5 indicators
  ema20          Float
  ema50          Float
  ema100         Float
  ema200         Float
  rsi14          Float
  macdLine       Float
  macdSignal     Float
  macdHist       Float
  atr14          Float
  atrPct         Float
  histVol        Float   @default(0)
  adx14          Float
  diPlus         Float
  diMinus        Float
  high52w        Float
  low52w         Float
  nearestSupport    Float?
  nearestResistance Float?
  distToSupport     Float?
  distToResistance  Float?
  avgVolume20    Float?
  relVolume      Float?
  currentRange   Float   @default(0)
  avgRange       Float   @default(0)

  // MA alignment flags
  priceAboveEma20   Boolean @default(false)
  priceAboveEma50   Boolean @default(false)
  priceAboveEma100  Boolean @default(false)
  priceAboveEma200  Boolean @default(false)
  ema20AboveEma50   Boolean @default(false)
  ema50AboveEma100  Boolean @default(false)
  ema100AboveEma200 Boolean @default(false)

  // Component scores (0–10 each)
  trendScore        Float
  momentumScore     Float
  volatilityScore   Float
  trendQualityScore Float
  maAlignmentScore  Float
  srScore           Float
  breakoutScore     Float
  volumeScore       Float

  // Labels
  trendLabel         String
  momentumLabel      String
  volatilityLabel    String
  trendQualityLabel  String
  quantLabel         String

  // Final weighted score 0–100
  finalQuantScore Float
  calculatedAt    DateTime @default(now())
  timeframe       String   @default("H1")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ideaId])
}

// ──────────────────────────────────────────────
// Market Pattern Scanner
// ──────────────────────────────────────────────

model ScannerResult {
  id              String   @id @default(cuid())
  symbol          String
  assetClass      String   @default("Other")
  description     String?
  pattern         String
  category        String
  direction       String
  timeframe       String
  tfLabel         String   @default("H1")
  currentPrice    Float
  breakoutLevel   Float
  entry           Float
  stop            Float
  target1         Float
  target2         Float
  target3         Float
  risk            Float
  reward          Float
  rrRatio         Float
  patternScore    Float
  patternQuality  Float    @default(0)
  trendQuality    Float    @default(0)
  volumeConf      Float    @default(0)
  breakoutProb    Float    @default(0)
  rrScore         Float    @default(0)
  classification  String
  status          String   @default("WATCH")
  commentary      String?  @db.Text
  holdingPeriod   String?
  atr             Float    @default(0)
  rsi             Float    @default(0)
  adx             Float    @default(0)
  isStarred       Boolean  @default(false)
  detectedAt      DateTime @default(now())
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  alerts          ScannerAlert[]
  watchedBy       ScannerWatchlistEntry[]

  @@index([symbol])
  @@index([pattern])
  @@index([direction])
  @@index([timeframe])
  @@index([patternScore])
  @@index([status])
  @@index([detectedAt])
  @@index([category])
}

model ScannerAlert {
  id        String        @id @default(cuid())
  resultId  String
  result    ScannerResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  alertType String
  message   String        @db.Text
  isRead    Boolean       @default(false)
  userId    String?
  createdAt DateTime      @default(now())

  @@index([resultId])
  @@index([isRead])
  @@index([userId])
  @@index([createdAt])
}

model ScannerWatchlistEntry {
  id        String        @id @default(cuid())
  userId    String
  resultId  String
  result    ScannerResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  note      String?
  createdAt DateTime      @default(now())

  @@unique([userId, resultId])
  @@index([userId])
}

model ScannerPerformanceLog {
  id           String   @id @default(cuid())
  symbol       String
  pattern      String
  category     String
  timeframe    String
  direction    String
  patternScore Float
  entryPrice   Float
  exitPrice    Float?
  returnPct    Float?
  holdingBars  Int?
  success      Boolean?
  failReason   String?
  createdAt    DateTime @default(now())
  closedAt     DateTime?

  @@index([pattern])
  @@index([success])
  @@index([createdAt])
}
