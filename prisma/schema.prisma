generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// Auth.js required models (Prisma adapter v2)
// ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// Core models
// ──────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  // Auth.js required fields
  name              String?
  email             String?   @unique
  emailVerified     DateTime?
  image             String?
  accounts          Account[]
  sessions          Session[]

  // Century Financial fields
  legacyId          String    @unique  // maps to old id like 'arun.john'
  displayName       String
  title             String
  role              Role
  tier              Tier
  passwordHash      String
  passwordChangedAt DateTime?           // null = never changed (force change on next login)
  passwordExpiresAt DateTime?
  failedAttempts    Int       @default(0)
  lockedUntil       DateTime?
  mfaEnabled        Boolean   @default(false)
  mfaSecret         String?             // AES-256-GCM encrypted TOTP secret
  mfaEnrolledAt     DateTime?
  pendingMfaSecret  String?             // Temp secret during enrollment flow

  // Performance metrics
  hitRate           Float     @default(0)
  avgRet            Float     @default(0)
  sharpe            Float     @default(0)
  drawCtrl          Float     @default(0)
  consistency       Float     @default(0)
  peerScore         Float     @default(0)
  ideaScore         Float     @default(0)
  allocScore        Float     @default(0)
  researchScore     Float     @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  passwordHistory   PasswordHistory[]
  resetTokens       PasswordResetToken[]
  mfaTokens         MfaToken[]
  auditLogs         AuditLog[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  // Extra tracking fields
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Short-lived token for MFA step-2 after password validation
model MfaToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  detail    String      @db.Text
  ipAddress String?
  device    String?
  risk      RiskLevel   @default(LOW)
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum Role {
  CIO
  PM
  SR_ANALYST
  ANALYST
}

enum Tier {
  A_PLUS
  A
  B
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGIN_MFA_SUCCESS
  LOGIN_MFA_FAILED
  LOGOUT
  SESSION_TERMINATED
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  MFA_ENROLLED
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  IDEA_SUBMITTED
  TRADE_APPROVED
  BALLOT_SUBMITTED
  PERMISSION_CHANGE
  VOTE_CAST
  ALLOCATION_ADJUSTED
  LOGIN_ANOMALY
  SESSION_STARTED
  RESEARCH_CREATED
  RESEARCH_UPDATED
  COMMENT_POSTED
  ATTACHMENT_ADDED
  WATCHLIST_CREATED
  CALENDAR_EVENT_ADDED
  POST_MORTEM_CREATED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String
  type      String
  createdAt DateTime @default(now())

  @@index([key, type, createdAt])
}

// ──────────────────────────────────────────────
// Phase 3 — Research OS models
// ──────────────────────────────────────────────

model ResearchDoc {
  id              String         @id @default(cuid())
  ideaId          String         @unique
  idea            Idea           @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  status          ResearchStatus @default(DRAFT)
  templateType    String?
  // Rich text sections (plain text / markdown stored)
  thesis          String?        @db.Text
  financials      String?        @db.Text
  valuation       String?        @db.Text
  technical       String?        @db.Text
  overview        String?        @db.Text
  // Computed scores (updated on save)
  completionScore Int            @default(0)
  qualityScore    Int            @default(0)
  authorId        String
  lastEditedBy    String?
  lastEditedAt    DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  versions    ResearchVersion[]
  catalysts   ResearchCatalyst[]
  risks       ResearchRisk[]
  attachments ResearchAttachment[]
  references  ResearchReference[]
  comments    ResearchComment[]

  @@index([authorId])
  @@index([status])
}

model ResearchVersion {
  id        String      @id @default(cuid())
  docId     String
  doc       ResearchDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  field     String
  content   String      @db.Text
  authorId  String
  createdAt DateTime    @default(now())

  @@index([docId, field])
}

model ResearchCatalyst {
  id             String      @id @default(cuid())
  docId          String
  doc            ResearchDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  title          String
  description    String      @db.Text
  expectedImpact String?
  probability    Int?
  timeline       String?
  importance     String      @default("MEDIUM")
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([docId])
}

model ResearchRisk {
  id             String      @id @default(cuid())
  docId          String
  doc            ResearchDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  description    String      @db.Text
  severity       String      @default("MEDIUM")
  probability    Int?
  mitigation     String?     @db.Text
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([docId])
}

model ResearchAttachment {
  id          String      @id @default(cuid())
  docId       String
  doc         ResearchDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  title       String
  description String?
  fileType    String
  fileUrl     String      @db.Text
  fileSize    Int?
  uploadedBy  String
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?

  @@index([docId])
}

model ResearchReference {
  id          String      @id @default(cuid())
  docId       String
  doc         ResearchDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  title       String
  source      String
  url         String?     @db.Text
  publishDate DateTime?
  notes       String?     @db.Text
  addedBy     String
  createdAt   DateTime    @default(now())

  @@index([docId])
}

model ResearchComment {
  id        String          @id @default(cuid())
  docId     String
  doc       ResearchDoc     @relation(fields: [docId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    ResearchComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   ResearchComment[] @relation("CommentReplies")
  authorId  String
  content   String          @db.Text
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?

  @@index([docId])
  @@index([parentId])
}

model Watchlist {
  id          String          @id @default(cuid())
  name        String
  description String?
  ownerId     String
  isPublic    Boolean         @default(false)
  color       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  items WatchlistItem[]

  @@index([ownerId])
}

model WatchlistItem {
  id          String    @id @default(cuid())
  watchlistId String
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  ticker      String
  notes       String?
  addedBy     String
  addedAt     DateTime  @default(now())

  @@unique([watchlistId, ticker])
  @@index([watchlistId])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  eventType   String
  date        DateTime
  ticker      String?
  ideaId      String?
  description String?  @db.Text
  importance  String   @default("MEDIUM")
  createdBy   String
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([ticker])
}

model PostMortem {
  id             String    @id @default(cuid())
  ideaId         String    @unique
  idea           Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  authorId       String
  entryDate      DateTime?
  exitDate       DateTime?
  entryPrice     Float?
  exitPrice      Float?
  actualReturn   Float?
  maxDrawdown    Float?
  holdDays       Int?
  originalThesis String?   @db.Text
  whatWorked     String?   @db.Text
  whatFailed     String?   @db.Text
  mistakes       String?   @db.Text
  lessonsLearned String?   @db.Text
  futureAction   String?   @db.Text
  committeeNotes String?   @db.Text
  rating         Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([authorId])
}

enum ResearchStatus {
  DRAFT
  IN_PROGRESS
  COMPLETE
  RISK_REVIEW
  COMMITTEE_REVIEW
  ARCHIVED
}

// ──────────────────────────────────────────────
// Business models
// ──────────────────────────────────────────────

model Idea {
  id              String         @id
  ticker          String
  assetClass      String         @default("US Equities")
  dir             Direction
  entry           Float
  stop            Float
  target          Float
  hold            String         @default("1-3M")
  posSize         Float          @default(1)
  conv            Int            @default(7)
  expRet          Float          @default(0)
  expDD           Float          @default(0)
  rr              Float          @default(0)
  thesis          String         @db.Text
  catalysts       String[]
  risks           String[]
  authorId        String
  submittedAt     DateTime       @default(now())
  weekId          String
  status          String         @default("ACTIVE")
  approvalStatus  ApprovalStatus @default(PENDING)
  imageUrl        String?        @db.Text
  totalCredits    Int            @default(0)
  rank            Int            @default(0)
  pmScore         Float          @default(0)
  skillScore      Float          @default(0)
  rrScore         Float          @default(0)
  quantScore      Float          @default(0)
  finalScore      Float          @default(0)
  momentumScore   Float          @default(0)
  rsScore         Float          @default(0)
  earningRevScore Float          @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  allocations     Allocation[]
  researchDoc     ResearchDoc?
  postMortem      PostMortem?

  @@index([weekId])
  @@index([authorId])
}

model Allocation {
  id          String   @id @default(cuid())
  userId      String
  ideaId      String
  amount      Int
  round       Int      @default(1)
  weekId      String
  submittedAt DateTime @default(now())
  idea        Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([userId, ideaId, round, weekId])
  @@index([weekId])
  @@index([userId, weekId])
}

enum Direction {
  LONG
  SHORT
}

enum ApprovalStatus {
  APPROVED
  PENDING
  REVIEW
  REJECTED
}
